# Recce backend environment — copy to backend/.env and fill in.
# backend/.env is gitignored. Never commit real keys.

# fal — serves all model calls (Claude Sonnet 4.6 text via openrouter/router).
FAL_KEY=

# Optional fal overrides (defaults shown). Re-point the model if 4.6 is
# unavailable on fal/OpenRouter (e.g. anthropic/claude-sonnet-4.5).
# FAL_LLM_ENDPOINT=openrouter/router
# FAL_LLM_MODEL=anthropic/claude-sonnet-4.6
# FAL_LLM_MAX_TOKENS=4096

# Supabase — Postgres persistence for story_sessions + scenes.
SUPABASE_URL=
SUPABASE_KEY=
